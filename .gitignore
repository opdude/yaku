# ── Build output ─────────────────────────────────────────────────────────────
bin/
build/.AppDir/
build/whisper/
build/tools/

# ── Wails generated bindings (regenerated by task / task dev) ─────────────────
cmd/yaku/frontend/wailsjs/
cmd/yaku/build/*
