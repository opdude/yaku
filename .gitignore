third_party/whisper.cpp/build/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Local planning docs ──────────────────────────────────────────────────────
plans/

# ── GoReleaser dist ───────────────────────────────────────────────────────────
dist/
.claude/
